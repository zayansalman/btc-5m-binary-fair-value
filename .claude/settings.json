{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "cd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null; ./.venv/bin/python tools/gen_docs.py --print-summary 2>/dev/null || python3 tools/gen_docs.py --print-summary 2>/dev/null || true" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "cd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null; ./.venv/bin/python tools/gen_docs.py --fast >/dev/null 2>&1 || python3 tools/gen_docs.py --fast >/dev/null 2>&1 || true" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "cd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null; ./.venv/bin/python tools/gen_docs.py --check 1>&2 2>/dev/null || true" }
        ]
      }
    ]
  }
}
