# Copy to .env locally (gitignored).

DATA_DIR=./data
DB_PATH=./data/btc_5m_binary_fair_value.db

# Local unauthenticated dashboard bind address.
# Keep 127.0.0.1 unless you deliberately want LAN/container access.
DASHBOARD_SERVER_NAME=127.0.0.1
DASHBOARD_SERVER_PORT=7860

# Active execution target: "paper" (default, simulated only) or "live".
# LIVE PLACES REAL ORDERS WITH REAL FUNDS on the Polymarket CLOB. Live mode
# refuses to boot unless POLYMARKET_PRIVATE_KEY is set AND
# BTC_LIVE_CONFIRM=YES_I_UNDERSTAND. It never silently falls back to paper.
BTC_BOT_MODE=paper
BTC_PAPER_MIN_TRADE_USD=1
BTC_PAPER_MAX_TRADE_USD=5
BTC_PAPER_TICK_SECONDS=5
BTC_PAPER_ENTRY_EDGE_MIN=0.045
BTC_PAPER_MIN_CONFIDENCE=0.50
BTC_PAPER_ENTRY_MIN_REMAINING_SECONDS=60
BTC_PAPER_TARGET_RETURN=0.10
BTC_PAPER_STOP_RETURN=-0.08
BTC_PAPER_TIME_EXIT_SECONDS=45

# Optional exported Polymarket CSV used only for sizing context.
BTC_HISTORY_CSV_PATH=./data/polymarket_history.csv

# Binance market-data endpoint. api.binance.com is unreachable from some
# networks; the .vision mirror serves identical /api/v3 market-data routes.
BINANCE_API_BASE=https://data-api.binance.vision

# --- Live trading (Polymarket CLOB) -----------------------------------------
# Only read when BTC_BOT_MODE=live. Keep the key OUT of git; this file ships
# with both wallet values empty on purpose.

# Polygon wallet private key used to sign CLOB orders. NEVER commit or log it.
POLYMARKET_PRIVATE_KEY=
# Funder (proxy wallet) address that holds your USDC on Polymarket. REQUIRED
# for signature types 1 and 2 — live boot REFUSES without it, because orders
# signed without a funder are rejected by the CLOB. Leave empty only for a
# plain EOA (type 0).
POLYMARKET_FUNDER=
# 0 = EOA, 1 = email/magic-link proxy wallet (default), 2 = browser wallet proxy.
POLYMARKET_SIGNATURE_TYPE=3   # 3=deposit wallet (recommended, via tools/live_setup.py), 0=EOA, 2=Gnosis Safe, 1=legacy proxy. NOTE: there is no key export in the Polymarket UI - see runbook 'Going Live'.

# Hard risk limits, enforced in code BEFORE every live order. NOTE: a typo in
# any of these (e.g. "O.50") makes live mode REFUSE to boot instead of
# silently trading on the looser default.
# Max USD notional per single trade.
BTC_LIVE_MAX_TRADE_USD=3
# Halt all new entries for the rest of the UTC day once realized PnL is at
# or below minus this amount. PERSISTED in SQLite — restarting the bot does
# NOT reset the counter within the same UTC day.
BTC_LIVE_DAILY_LOSS_HALT_USD=10
# OPTIONAL cap on the SUM of all live buy notionals per UTC day. Leave blank
# (or unset, or set to 0) to DISABLE the cap — the bot trades each new edge
# without a daily budget ceiling. When set to a positive dollar amount the
# counter is persisted in SQLite, so Stop/Start does not grant a fresh
# bankroll within the same UTC day. The daily-spend tracker keeps running
# either way so the dashboard can show throughput when the cap is off.
BTC_LIVE_BANKROLL_CAP_USD=
# Block an entry when the live best ask sits more than this far above the
# signal price that produced the edge (thin 5m books can gap badly).
BTC_LIVE_MAX_ENTRY_SLIPPAGE=0.02
# How long an exit SELL may rest before it is cancelled and retried at the
# new best bid (exit orders never rest beyond this bound).
BTC_LIVE_EXIT_FILL_TIMEOUT_SECONDS=10

# Type the exact phrase YES_I_UNDERSTAND to allow live mode to boot.
BTC_LIVE_CONFIRM=

# Kill switch: create this file (e.g. `touch data/KILL`) to immediately block
# all NEW entries and cancel resting orders. Open positions are still
# flattened by the exit path — flattening only reduces exposure. Delete the
# file to re-arm; touching it again later triggers the cancel sweep again.
#KILL_SWITCH_PATH=./data/KILL

# Trade shape: 'settle' (default — one entry per window, hold to Chainlink
# resolution, spread paid once; winners need operator redemption in the UI)
# or 'scalp' (legacy intra-window exits; lost money under honest fills).
BTC_EXIT_STYLE=settle

# Anti-adverse-selection entry filters (issue #29, from 26h soak n=225):
# reject "too good" edges (stale model) and longshot entries below 50c.
BTC_PAPER_ENTRY_EDGE_MAX=0.07
BTC_PAPER_MIN_ENTRY_PRICE=0.50

# Adaptive risk controller (issue #36): pause new entries on edge decay.
BTC_AUTO_PAUSE_ENABLED=true
BTC_AUTO_PAUSE_WINDOW=20
BTC_AUTO_PAUSE_MIN_TRADES=10
BTC_AUTO_PAUSE_MIN_ROI=-0.15
